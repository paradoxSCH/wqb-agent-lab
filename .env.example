# WorldQuant BRAIN 账号
WQB_EMAIL=
WQB_PASSWORD=

# 可选 LLM Provider 凭证。只在选择对应 provider 时填写本地 .env
OPENAI_API_KEY=
# Anthropic 原生 Provider
ANTHROPIC_API_KEY=
# Gemini 原生 Provider
GEMINI_API_KEY=

# 默认模拟参数
WQB_REGION=USA
WQB_UNIVERSE=TOP3000
WQB_DELAY=1
WQB_DECAY=13
WQB_NEUTRALIZATION=INDUSTRY
WQB_TRUNCATION=0.13

# 并发参数
WQB_MAX_CONCURRENCY=8
WQB_MULTI_ALPHA_BATCH_SIZE=10

# 请求重试参数
WQB_REQUEST_MAX_ATTEMPTS=3
WQB_REQUEST_BACKOFF_SECONDS=1.0

# 自主执行 capability：行为配置只表达意图，真实平台副作用仍需逐项显式授权
WQB_LIVE_SIMULATION_CAPABILITY=0
WQB_LIVE_SUBMIT_CAPABILITY=0

# 日志级别
WQB_LOG_LEVEL=INFO
