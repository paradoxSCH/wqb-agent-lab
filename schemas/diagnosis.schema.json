{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wqb-agent-lab.local/schemas/diagnosis.schema.json",
  "title": "Diagnosis",
  "type": "object",
  "required": ["diagnosis_id", "diagnosis_type", "severity", "policy_action", "evidence"],
  "additionalProperties": false,
  "properties": {
    "diagnosis_id": { "type": "string" },
    "diagnosis_type": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "policy_action": {
      "type": "string",
      "enum": ["block", "repair", "retry", "scale", "submit", "holdout", "observe"]
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "candidate_id": { "type": "string" },
    "alpha_id": { "type": "string" }
  }
}
