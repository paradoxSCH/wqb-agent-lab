{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wqb-agent-lab.local/schemas/run_manifest.schema.json",
  "title": "Run Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "code",
    "runtime",
    "configuration",
    "llm",
    "research",
    "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "enum": [1] },
    "run_id": { "type": "string" },
    "created_at": { "type": "string" },
    "code": {
      "type": "object",
      "additionalProperties": true
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true
    },
    "configuration": {
      "type": "object",
      "additionalProperties": true
    },
    "llm": {
      "type": "object",
      "additionalProperties": true
    },
    "research": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "sha256", "size_bytes"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "sha256": { "type": "string" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "schema_name": { "type": "string" },
          "schema_digest": { "type": "string" },
          "producer": { "type": "string" },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
